ARG BASE_CONTAINER=quay.io/jupyter/minimal-notebook
FROM $BASE_CONTAINER
LABEL maintainer=rcmlz
ENV DEBIAN_FRONTEND=noninteractive

###############################################################################
# apt
###############################################################################
WORKDIR /tmp
USER root
COPY apt-minimal.txt apt.txt
RUN    apt-get update -y \
    && grep -vE '^#' apt.txt | xargs apt-get install --yes --no-install-recommends

###############################################################################
# pip
###############################################################################
WORKDIR /tmp
USER root
COPY requirements-minimal.txt requirements.txt
RUN pip install -r requirements.txt

###############################################################################
# Rust
###############################################################################
WORKDIR /tmp
USER "${NB_UID}"
ENV PATH=$PATH:/home/jovyan/.cargo/bin
RUN curl https://sh.rustup.rs -sSf | sh -s -- -y \
    && source $HOME/.cargo/env \
    && echo 'source $HOME/.cargo/env' >> $HOME/.bashrc \
    && cargo install evcxr_jupyter --no-default-features \
    && evcxr_jupyter --install

###############################################################################
# zef and raku packages
###############################################################################
WORKDIR /tmp
USER "${NB_UID}"
ENV PATH="$PATH:$HOME/.raku/bin"
COPY raku-packages-minimal.txt /tmp/raku-packages.txt
RUN git clone --depth 1 https://github.com/ugexe/zef.git \
    && cd zef \
    && raku -I. bin/zef install --/test . \
    && ZEF_TEST_DEGREE=`raku -e "say $*Kernel.cpu-cores"` \
    && ZEF_FETCH_DEGREE=$ZEF_TEST_DEGREE \
    && zef update \
    && cat /tmp/raku-packages.txt | raku -e 'for $*IN.lines.grep(/^^\w/) { say shell "zef install --/test \"$_\"" }' \
    && jupyter-chatbook-raku --generate-config --location=$HOME/.local/share/jupyter/kernels/raku-chatbook

###############################################################################
# clean up
###############################################################################
WORKDIR /tmp
USER root
RUN rm -rf ${NB_UID}/.git ${NB_UID}/.cache ${NB_UID}/.yarn ${NB_UID}/.cpan ${NB_UID}/.cpanm ${NB_UID}/.empty ${NB_UID}/.npm
RUN    rm -rf /tmp/* \
    && rm -rf ${HOME}/.git ${HOME}/.cache ${HOME}/.yarn ${HOME}/.cpan ${HOME}/.cpanm ${HOME}/.empty ${HOME}/.npm \
    && rm -rf /root/* \
    && find /var/log -type f -print0 | xargs -0 truncate -s 0 \
    && apt-get clean && apt-get autoclean && rm -rf /var/lib/apt/lists/* \
    && fix-permissions "${HOME}"

###############################################################################
# ready for starting jupyter
###############################################################################
SHELL ["/bin/bash", "-l", "-c"]
USER "${NB_UID}"
WORKDIR "${HOME}"
